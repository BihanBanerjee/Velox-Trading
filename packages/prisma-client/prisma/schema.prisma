generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Asset {
  BTCUSDT
  ETHUSDT
  SOLUSDT
}

enum OrderType {
  LONG
  SHORT
}

enum OrderStatus {
  OPEN
  CLOSED
  LIQUIDATED
}


model User {
  id        String        @id @default(uuid())
  email     String        @unique
  phone     Int           @unique
  password  String
}


model ClosedOrder {
  orderId         String        @id
  userId          String
  asset           Asset
  orderType       OrderType
  leverage        Int
  marginInt       BigInt
  executionPoint  BigInt
  closePriceInt   BigInt
  qtyInt          BigInt
  stopLossInt     BigInt
  takeProfitInt   BigInt
  finalPnLInt     BigInt
  createdAt       DateTime
  closedAt        DateTime

  @@index([userId, closedAt])
  @@index([closedAt])
  @@index([asset])
  @@map("closed_orders")
}

model Trade {
  id              String          @default(cuid())
  time            DateTime        @db.Timestamptz
  symbol          String
  priceInt        BigInt          // Prices as integer(scaled by 10^8)
  qtyInt          BigInt          // Quantity as integer(scaled by 10^8)
  createdAt       DateTime        @default(now())

  @@id([id, time])
  @@index([symbol, time])
  @@index([time])
  @@map("trades")
}